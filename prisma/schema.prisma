generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  HR
  ORG
  ADMIN
  INSTITUTION
}

enum ExperienceLevel {
  FRESHER
  EXPERIENCED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(STUDENT)
  organisation String?
  phone        String?
  degree       String?
  gradYear     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profile       StudentProfile?
  mentorProfile MentorProfile?
  jobPostings   JobPosting[]
  applications  Application[]
  payments      Payment[]
  subscription  Subscription?
  createdEvents Event[]              @relation("EventCreator")
  eventRegs     EventRegistration[]  @relation("EventRegistrations")
  profileViews  ProfileView[]       @relation("ProfileViewer")
}

model ProfileView {
  id          String   @id @default(cuid())
  viewerId    String
  viewer      User     @relation("ProfileViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  profileId   String
  viewedAt    DateTime @default(now())

  @@unique([viewerId, profileId])
}

enum MentorStatus {
  PENDING
  VERIFIED
  UNVERIFIED
  SUSPENDED
}

enum CompensationType {
  PAID
  VOLUNTEER
}

model MentorProfile {
  id                String          @id @default(cuid())
  mentorNumber      String          @unique
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Verification
  status            MentorStatus    @default(PENDING)
  verifiedAt        DateTime?

  // Basic
  headline          String?         // e.g. "Senior Cybersecurity Analyst at TCS"
  bio               String?
  currentCompany    String?
  currentRole       String?
  collegeName       String?

  // Experience
  yearsOfExperience Int             @default(0)
  companiesWorked   String[]        // list of company names
  areaOfExpertise   String[]        // e.g. ["Cybersecurity", "Cloud"]

  // Mentoring
  menteesHelped     Int             @default(0)
  rating            Float           @default(0)
  totalSessions     Int             @default(0)
  compensation      CompensationType @default(PAID)
  sessionRate       Int?            // per session rate in INR (if paid)
  availability      String?         // "1-2 hours/week", etc.

  // Links
  linkedinUrl       String?
  profilePhotoUrl   String?

  // Achievements
  achievements      MentorAchievement[]

  // Skills they mentor on
  mentorTopics      String[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model MentorAchievement {
  id          String        @id @default(cuid())
  profileId   String
  profile     MentorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  description String?
  imageUrl    String?
}

model StudentProfile {
  id              String          @id @default(cuid())
  profileNumber   String          @unique
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Institution link (if enrolled through a college)
  institutionId   String?

  // Basic info
  collegeName     String?
  experienceLevel ExperienceLevel @default(FRESHER)
  fieldOfInterest String?
  bio             String?

  // Academic
  academicScore   String?
  academicType    String?         // "CGPA", "Percentage", "GPA"

  // Job preferences
  salaryMin       Int?
  salaryMax       Int?
  availableToJoin Boolean         @default(true)
  joinDate        String?         // "Immediately", "15 days", "30 days", "60 days+"

  // Links
  resumeUrl       String?
  githubUrl       String?
  linkedinUrl     String?
  portfolioUrl    String?
  otherLinks      String[]

  // Experience (for experienced candidates)
  experiences     Experience[]

  // Certifications
  certifications  Certification[]

  // Profile score (computed fields stored)
  profileScore    Int             @default(0)

  // Skills
  skills          String[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Experience {
  id          String         @id @default(cuid())
  profileId   String
  profile     StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company     String
  role        String
  startDate   String
  endDate     String?        // null = currently working
  description String?
  current     Boolean        @default(false)
}

model Certification {
  id          String         @id @default(cuid())
  profileId   String
  profile     StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  issuer      String
  issueDate   String?
  imageUrl    String?        // base64 or URL of certificate
}

enum JobStatus {
  ACTIVE
  CLOSED
  DRAFT
  UNDER_REVIEW
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  ASSESSMENT
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

model JobPosting {
  id              String        @id @default(cuid())
  postedById      String
  postedBy        User          @relation(fields: [postedById], references: [id], onDelete: Cascade)

  title           String
  company         String
  location        String
  workMode        String        // "On-site", "Remote", "Hybrid"
  salaryMin       Int?
  salaryMax       Int?
  experienceLevel String        // "Fresher", "1 year", etc.
  urgency         String        // "Urgent", "Within 15 days", etc.
  jobType         String        // "Full-time", "Part-time", etc.
  domain          String?
  department      String?
  description     String
  skills          String[]
  perks           String?
  deadline        DateTime?
  openings        Int           @default(1)

  status          JobStatus     @default(ACTIVE)
  applications    Application[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Application {
  id            String            @id @default(cuid())
  jobId         String
  job           JobPosting        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  status        ApplicationStatus @default(APPLIED)
  scoreMatch    Int               @default(0)  // 0-100 match percentage
  coverNote     String?
  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([jobId, userId])       // one application per job per user
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum PlanType {
  FREE
  CAREER_READY
  INSTITUTION
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?

  amount            Int           // in paise (29900 = ₹299)
  currency          String        @default("INR")
  status            PaymentStatus @default(CREATED)
  plan              PlanType      @default(CAREER_READY)

  description       String?
  receipt           String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan        PlanType @default(FREE)
  active      Boolean  @default(true)
  expiresAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum EventStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum EventType {
  VIRTUAL
  PHYSICAL
  HYBRID
}

enum EventPricing {
  FREE
  PAID
}

model Event {
  id              String          @id @default(cuid())
  createdById     String
  createdBy       User            @relation("EventCreator", fields: [createdById], references: [id], onDelete: Cascade)

  title           String
  description     String
  agenda          String?
  benefits        String?
  date            DateTime
  endDate         DateTime?
  duration        String?         // "1 hour", "2 hours", etc.
  eventType       EventType       @default(VIRTUAL)
  location        String?         // physical address or city

  // Pricing
  pricing         EventPricing    @default(FREE)
  price           Int?            // in paise (e.g. 49900 = ₹499)

  // Capacity
  minParticipants Int             @default(1)
  maxParticipants Int             @default(100)

  // Join link — hidden for paid events until payment
  joinLink        String?         // Zoom/Meet link
  joinInstructions String?

  // Status
  status          EventStatus     @default(PENDING_APPROVAL)
  approvedAt      DateTime?
  rejectedReason  String?

  // Meta
  category        String?         // "Career Guidance", "Resume Review", etc.
  tags            String[]
  coverImageUrl   String?

  registrations   EventRegistration[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model EventRegistration {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("EventRegistrations", fields: [userId], references: [id], onDelete: Cascade)

  paid        Boolean  @default(false)
  paymentId   String?  // razorpay payment ID if paid
  joinedAt    DateTime @default(now())

  @@unique([eventId, userId])
}
