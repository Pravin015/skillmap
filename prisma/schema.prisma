generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  HR
  ORG
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(STUDENT)
  organisation String?
  phone        String?
  degree       String?
  gradYear     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
