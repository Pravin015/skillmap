generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  HR
  ORG
  ADMIN
}

enum ExperienceLevel {
  FRESHER
  EXPERIENCED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(STUDENT)
  organisation String?
  phone        String?
  degree       String?
  gradYear     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profile       StudentProfile?
  mentorProfile MentorProfile?
  jobPostings   JobPosting[]
  applications  Application[]
}

enum MentorStatus {
  PENDING
  VERIFIED
  UNVERIFIED
  SUSPENDED
}

enum CompensationType {
  PAID
  VOLUNTEER
}

model MentorProfile {
  id                String          @id @default(cuid())
  mentorNumber      String          @unique
  userId            String          @unique
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Verification
  status            MentorStatus    @default(PENDING)
  verifiedAt        DateTime?

  // Basic
  headline          String?         // e.g. "Senior Cybersecurity Analyst at TCS"
  bio               String?
  currentCompany    String?
  currentRole       String?
  collegeName       String?

  // Experience
  yearsOfExperience Int             @default(0)
  companiesWorked   String[]        // list of company names
  areaOfExpertise   String[]        // e.g. ["Cybersecurity", "Cloud"]

  // Mentoring
  menteesHelped     Int             @default(0)
  rating            Float           @default(0)
  totalSessions     Int             @default(0)
  compensation      CompensationType @default(PAID)
  sessionRate       Int?            // per session rate in INR (if paid)
  availability      String?         // "1-2 hours/week", etc.

  // Links
  linkedinUrl       String?
  profilePhotoUrl   String?

  // Achievements
  achievements      MentorAchievement[]

  // Skills they mentor on
  mentorTopics      String[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model MentorAchievement {
  id          String        @id @default(cuid())
  profileId   String
  profile     MentorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  description String?
  imageUrl    String?
}

model StudentProfile {
  id              String          @id @default(cuid())
  profileNumber   String          @unique
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Basic info
  collegeName     String?
  experienceLevel ExperienceLevel @default(FRESHER)
  fieldOfInterest String?
  bio             String?

  // Academic
  academicScore   String?
  academicType    String?         // "CGPA", "Percentage", "GPA"

  // Job preferences
  salaryMin       Int?
  salaryMax       Int?
  availableToJoin Boolean         @default(true)
  joinDate        String?         // "Immediately", "15 days", "30 days", "60 days+"

  // Links
  resumeUrl       String?
  githubUrl       String?
  linkedinUrl     String?
  portfolioUrl    String?
  otherLinks      String[]

  // Experience (for experienced candidates)
  experiences     Experience[]

  // Certifications
  certifications  Certification[]

  // Profile score (computed fields stored)
  profileScore    Int             @default(0)

  // Skills
  skills          String[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Experience {
  id          String         @id @default(cuid())
  profileId   String
  profile     StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company     String
  role        String
  startDate   String
  endDate     String?        // null = currently working
  description String?
  current     Boolean        @default(false)
}

model Certification {
  id          String         @id @default(cuid())
  profileId   String
  profile     StudentProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  issuer      String
  issueDate   String?
  imageUrl    String?        // base64 or URL of certificate
}

enum JobStatus {
  ACTIVE
  CLOSED
  DRAFT
  UNDER_REVIEW
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  ASSESSMENT
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

model JobPosting {
  id              String        @id @default(cuid())
  postedById      String
  postedBy        User          @relation(fields: [postedById], references: [id], onDelete: Cascade)

  title           String
  company         String
  location        String
  workMode        String        // "On-site", "Remote", "Hybrid"
  salaryMin       Int?
  salaryMax       Int?
  experienceLevel String        // "Fresher", "1 year", etc.
  urgency         String        // "Urgent", "Within 15 days", etc.
  jobType         String        // "Full-time", "Part-time", etc.
  domain          String?
  department      String?
  description     String
  skills          String[]
  perks           String?
  deadline        DateTime?
  openings        Int           @default(1)

  status          JobStatus     @default(ACTIVE)
  applications    Application[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Application {
  id            String            @id @default(cuid())
  jobId         String
  job           JobPosting        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  status        ApplicationStatus @default(APPLIED)
  scoreMatch    Int               @default(0)  // 0-100 match percentage
  coverNote     String?
  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([jobId, userId])       // one application per job per user
}
