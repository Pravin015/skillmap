# ════════════════════════════════════════════════════════════════════════
# AstraaHire — production env vars
# Copy this file to Railway → Variables. Never commit the real values.
# Sections marked CRITICAL must be set or the app will not work.
# Sections marked OPTIONAL can be skipped at first launch.
# ════════════════════════════════════════════════════════════════════════


# ──────────── DATABASE — CRITICAL ────────────
# Postgres connection string. Railway provides this automatically when you
# attach the Postgres plugin — copy from the plugin's "Connect" tab.
DATABASE_URL=postgresql://user:pass@host:5432/dbname


# ──────────── AUTH — CRITICAL ────────────
# 1. NEXTAUTH_SECRET — random 32+ char string used to sign JWTs.
#    Generate:  openssl rand -hex 32
NEXTAUTH_SECRET=replace-with-32-char-random-hex

# 2. NEXTAUTH_URL — public URL of your deployed app (no trailing slash).
#    Required for OAuth callbacks and password-reset email links.
NEXTAUTH_URL=https://astraahire.com


# ──────────── CLAUDE / AI — CRITICAL ────────────
# Used by /api/chat, /api/mock-interviews/*, /api/candidates/match-jd
# Get from: https://console.anthropic.com/settings/keys
# Anthropic SDK reads ANTHROPIC_API_KEY automatically — no code change needed.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ──────────── PAYMENTS (Razorpay) — CRITICAL FOR PREMIUM ────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use TEST keys (rzp_test_*) until launch, then swap to LIVE keys.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret — get from Razorpay dashboard → Webhooks tab.
# Webhook URL to configure there: https://astraahire.com/api/payments/webhook
# Subscribe to events: payment.captured, payment.failed, refund.processed
RAZORPAY_WEBHOOK_SECRET=replace-with-webhook-signing-secret


# ──────────── EMAIL (Resend) — CRITICAL ────────────
# OTP delivery + password reset + transactional emails depend on this.
# Get key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address — must be on a verified domain.
# Verify your domain at: https://resend.com/domains
RESEND_FROM_EMAIL=AstraaHire <noreply@astraahire.com>


# ──────────── FILE STORAGE (Google Cloud Storage) — CRITICAL FOR UPLOADS ────────────
# Profile photos, resume uploads, certificate exports.
# 1. Create a GCS bucket (uniform access, public-read ACL).
# 2. Create a service account with "Storage Object Admin" role on that bucket.
# 3. Download the service-account JSON key.
# 4. Paste the ENTIRE JSON below as a single-line string.
GCS_BUCKET=astraahire-prod
GCS_KEY_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}


# ──────────── JOB SCRAPER — REQUIRED FOR /jobs/external ────────────
# Adzuna provides a free 1000 calls/day tier — perfect for our use.
# Sign up: https://developer.adzuna.com/signup  (2-min process)
ADZUNA_APP_ID=xxxxxxxx
ADZUNA_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cron endpoint protection. Generate any random 32-char hex.
# Generate:  openssl rand -hex 32
# Used by:  POST /api/cron/scrape-jobs  (header: x-cron-secret)
CRON_SECRET=replace-with-32-char-random-hex


# ──────────── ENVIRONMENT FLAG ────────────
NODE_ENV=production
